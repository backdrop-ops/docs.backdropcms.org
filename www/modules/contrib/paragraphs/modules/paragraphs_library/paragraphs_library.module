/**
 * Implements hook_theme().
 */
function paragraphs_library_theme($existing, $type, $theme, $path) {
  $items = [];

  $items['paragraphs_library_item'] = [
    'render element' => 'element',
    'template' => 'paragraphs-library-item',
    'path' => $path . '/theme',
    'file' => 'paragraphs_library.theme.inc',
    'attached' => [
      'css' => [
        $path . '/css/paragraphs-library-item.css',
      ],
    ],
  ];

  return $items;
}

