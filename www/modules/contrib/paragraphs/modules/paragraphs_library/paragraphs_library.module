<?php
/**
 * @file
 * Paragraphs library hook implementations and other functions.
 */

 define('PARAGRAPHS_LIBRARY_REVISIONS', TRUE);

/**
 * Implements hook_config_info().
 */
function paragraphs_library_config_info() {
  $prefixes['paragraphs_library.type'] = [
    'name_key' => 'type',
    'label_key' => 'label',
    'group' => t('Paragraphs library types'),
  ];
  return $prefixes;
}

/**
 * Implements hook_entity_info().
 */
function paragraphs_library_entity_info() {
  $entity_info = [
    'paragraphs_library_item' => [
      'label' => t('Paragraphs library item'),
      'plural label' => t('Paragraphs library items'),
      'entity class' => 'ParagraphsLibraryItem',
      'controller class' => 'ParagraphsLibraryItemController',
      'base table' => 'paragraphs_library_item',
      'fieldable' => TRUE,
      'entity keys' => [
        'id' => 'item_id',
        'bundle' => 'type',
        'label' => 'title',
        'revision' => 'revision_id',
      ],
      'revision table' => 'paragraphs_library_item_revision',
      'bundle keys' => [
        'bundle' => 'type',
      ],
      'bundles' => [],
      'view modes' => [
        'paragraphs_library_item' => [
          'label' => 'Paragraphs library item preview',
          'custom settings' => FALSE,
        ],
        'full' => [
          'label' => 'Full',
          'custom settings' => TRUE,
        ],
      ],
      'module' => 'paragraphs_library',

      // While this key is not defined in hook_entity_info(), we use it for
      // convenience, providing an easier way to check access outside the class.
      'access callback' => 'paragraphs_library_access',

      // This controller is used to display non Field API extra fields.
      'extra fields controller class' => 'EntityDefaultExtraFieldsController',

      // By including 'admin ui' we are telling Entity UI to create menu items
      // for viewing, adding, editing and deleting paragraphs_library_item entities.
      'admin ui' => [
        'path' => 'admin/content/paragraphs/library',
        'controller class' => 'EntityBundleableUIController',
        'file' => 'paragraphs_library.admin.inc',
        'menu wildcard' => '%paragraphs_library_item',
      ],

      // This tells Entity Plus to make the text entered in the entity
      // properties (e.g. title) available to i18n_string for translations.
      'i18n controller class' => 'EntityDefaultI18nStringController',
    ],
  ];

  // Bundles must provide a human readable name so we can create help and error
  // messages, and the path to attach Field admin pages to.
  // node_type_cache_reset();
  foreach (paragraphs_library_type_load() as $type) {
    $entity_info['paragraphs_library_item']['bundles'][$type->type] = [
      'label' => $type->label,
      'admin' => [
        'path' => 'admin/structure/paragraphs/library/types/%paragraphs_library_type',
        'real path' => 'admin/structure/paragraphs/library/types/' . str_replace('_', '-', $type->type),
        'bundle argument' => 5,
        'access arguments' => ['administer paragraphs_library types'],
      ],
    ];
  }

  return $entity_info;
}

/**
 * Implements hook.autoload_info().
 */
function paragraphs_library_autoload_info() {
  return [
    'ParagraphsLibraryItem' => 'paragraphs_library.class.inc',
    'ParagraphsLibraryItemController' => 'paragraphs_library.controller.inc',
    'views_handler_field_paragraphs_library_link_edit' => 'views/views_handler_field_paragraphs_library_link_edit.inc',
    'views_handler_field_paragraphs_library_link' => 'views/views_handler_field_paragraphs_library_link.inc',
    'views_handler_field_paragraphs_library_link_delete' => 'views/views_handler_field_paragraphs_library_link_delete.inc',
  ];
}

