      'title' => t('Create Paragraphs library items'),
      'description' => t('Allows users to create Paragraphs library items.'),
      'restrict access' => TRUE,
    ],
    'view own paragraphs_library_item entities' => [
      'title' => t('View own Paragraphs library items'),
      'description' => t('Allows users to view own Paragraphs library items.'),
    ],
    'view paragraphs_library_item entities' => [
      'title' => t('View Paragraphs library items'),
